#!/bin/sh
# 코더 push 금지 게이트 (git pre-push). 코더 워크트리(.agent-coder-guard 마커 존재)에서는
# push 를 전면 차단한다 — 클라우드·원격 반영은 검증 통과 후 검증자만.
# 마커 없는 planner 워크트리는 영향 없음 (동일 hooksPath 를 공유해도 워크트리별로 갈린다).
#
# 설치: setup-worktree.sh --hooks-src templates/hooks  (core.hooksPath .githooks 자동 설정)
# 우회: git push --no-verify (의도된 예외 — 검증자만, 사유를 저널에 남길 것)

top=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
if [ -n "$top" ] && [ -f "$top/.agent-coder-guard" ]; then
  echo "차단: 코더 워크트리는 push 금지 (원격 반영은 검증자 전담)." >&2
  echo "      검증 통과 후 검증자가 main 에서 push 한다." >&2
  exit 1
fi
exit 0
