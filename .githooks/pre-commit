#!/bin/sh
# git pre-commit 가드 — 저장소 수준이므로 커밋하는 *모든* 에이전트에 적용.
#  (A) 코더 브랜치 게이트: .agent-coder-guard 마커가 있는 워크트리에서 main/master 직접 커밋 차단
#  (B) append-only 저널 가드: TURN_LOG.md / TURN_LOG-archive-*.md 의 기존 줄 삭제·수정 차단
#      (append-only 는 merge=union 안전성의 전제 — 권고로는 못 지킨다)
#
# 설치(둘 중 하나):
#   1) 단일 체크아웃:  cp templates/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#   2) 워크트리 공유:   mkdir -p .githooks && cp templates/hooks/pre-commit .githooks/ \
#                       && chmod +x .githooks/pre-commit && git config core.hooksPath .githooks
#      (코더 게이트는 setup-worktree.sh 가 마커까지 배치)
#
# 우회: git commit --no-verify (로테이션 스크립트가 사용). 훅은 문턱을 올릴 뿐,
#       Gotcha 2 의 "검증자 외부 상태 실측" 원칙을 대체하지 않는다.

# (A) 코더 브랜치 게이트 — 마커 있는 워크트리에서 main/master 직접 커밋 차단
top=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
if [ -n "$top" ] && [ -f "$top/.agent-coder-guard" ]; then
  br=$(git symbolic-ref --short HEAD 2>/dev/null || echo "DETACHED")
  case "$br" in
    main|master)
      echo "차단: 코더 워크트리에서 $br 직접 커밋 금지 — wo/NNN 브랜치에서 작업하세요." >&2
      echo "      머지는 검증 통과 후 검증자만 수행합니다." >&2
      exit 1 ;;
  esac
fi

# (B) append-only 저널 가드
files=$(git diff --cached --name-only --diff-filter=ACMR \
        | grep -E '(^|/)TURN_LOG(-archive-[0-9]{6})?\.md$' || true)
[ -z "$files" ] && exit 0

fail=0
for f in $files; do
  # 추가(A)만 있는 신규 파일은 삭제 줄이 없어 통과. 수정된 줄은 -old/+new 로 삭제 줄이 잡힘.
  removed=$(git diff --cached --unified=0 -- "$f" \
            | grep -E '^-' | grep -vE '^--- ' | wc -l | tr -d ' ')
  if [ "$removed" -gt 0 ]; then
    echo "차단: $f 는 append-only 인데 기존 ${removed}줄이 삭제/수정되었습니다." >&2
    fail=1
  fi
done

if [ "$fail" -ne 0 ]; then
  echo "" >&2
  echo "저널은 끝에 추가만 허용됩니다. 로테이션이 필요하면 rotate-journal.sh 를 쓰세요." >&2
  echo "의도된 예외라면: git commit --no-verify" >&2
  exit 1
fi
exit 0
